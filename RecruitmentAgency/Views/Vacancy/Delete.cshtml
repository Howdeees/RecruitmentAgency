@model RecruitmentAgency.Models.Vacancy

@{
    ViewData["Title"] = "Удаление вакансии";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card border-danger shadow-sm">
                <div class="card-body p-5">
                    <div class="text-danger mb-4">
                        <i class="bi bi-exclamation-triangle-fill" style="font-size: 3rem;"></i>
                    </div>
                    <h3 class="mb-3">Удалить вакансию?</h3>
                    <p class="text-muted mb-4">
                        Вы собираетесь безвозвратно удалить вакансию <strong>"@Model.Title"</strong>.
                        Это действие нельзя будет отменить.
                    </p>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-center gap-3">
                            <a asp-action="Index" class="btn btn-light border px-4">Отмена</a>
                            <button type="submit" class="btn btn-danger px-4 shadow-sm">Да, удалить</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>