@model IEnumerable<RecruitmentAgency.Models.Vacancy>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-6 fw-bold">Мои вакансии</h1>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Разместить новую
        </a>
    </div>

    <div class="row g-3">
        @foreach (var item in Model)
        {
            <div class="col-12">
                <div class="card shadow-sm border-0 border-start border-4 border-primary">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-1 fw-bold">@item.Title</h5>
                            <span class="text-muted small">
                                <i class="bi bi-calendar-event me-1"></i> Создана: @item.CreatedDate.ToString("dd.MM.yyyy")
                            </span>
                            <span class="badge bg-light text-dark border ms-2">@item.Schedule</span>
                        </div>
                        
                        <div class="d-flex gap-3 align-items-center">

                            <a asp-controller="Application" asp-action="Incoming" asp-route-vacancyId="@item.Id"
                                   class="text-decoration-none text-center me-4">
                                <div class="h4 mb-0 text-primary">@item.Applications?.Count()</div>
                                <div class="small text-muted">откликов</div>
                            </a>

                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                      onsubmit="return confirm('Вы уверены, что хотите удалить эту вакансию и все отклики на неё?');"
                                      class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash me-1"></i> Удалить
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>