@model IEnumerable<RecruitmentAgency.Models.Vacancy>

@{
    ViewData["Title"] = "Вакансии";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h1 class="display-6">Список вакансий</h1>
    <a asp-action="Create" class="btn btn-success shadow-sm">
        + Создать вакансию
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center" role="alert">
        На данный момент нет доступных вакансий. Будьте первым, кто разместит предложение!
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 bg-light">
                    <div class="card-body">
                        <h5 class="card-title text-primary fw-bold">@item.Title</h5>
                        <h6 class="card-subtitle mb-3 text-success fw-bold">
                            @* Форматируем зарплату (например, добавив "руб.") *@
                            @item.Salary.ToString("N0") руб.
                        </h6>
                        
                        <p class="card-text text-muted mb-4" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                            @item.Description
                        </p>

                        <ul class="list-unstyled mb-0 small">
                            <li class="mb-1">
                                <strong>График:</strong> <span class="badge bg-secondary">@item.Schedule</span>
                            </li>
                            <li class="mb-1">
                                <strong>Требования:</strong> <span class="text-truncate d-inline-block align-bottom" style="max-width: 150px;">@item.Requirements</span>
                            </li>
                            <li>
                                <strong>Опубликовано:</strong> @item.CreatedDate.ToString("dd.MM.yyyy")
                            </li>
                        </ul>
                    </div>
                    
                    <div class="card-footer bg-white border-0 pt-0 pb-3">
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-sm px-3">Откликнуться / Детали</a>
                            
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm" title="Редактировать">✎</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm" title="Удалить">✖</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}