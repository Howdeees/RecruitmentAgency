@model RecruitmentAgency.Models.Vacancy

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Все вакансии</a></li>
            <li class="breadcrumb-item active">@Model.Title</li>
        </ol>
    </nav>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h2 class="mb-0 text-primary">@Model.Title</h2>
                <span class="badge bg-success fs-5">@Model.Salary.ToString("N0") руб.</span>
            </div>
        </div>
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-8">
                    <h5 class="fw-bold"><i class="bi bi-info-circle me-2"></i>Описание работы</h5>
                    <p class="text-secondary" style="white-space: pre-line;">@Model.Description</p>

                    <h5 class="fw-bold mt-4"><i class="bi bi-list-check me-2"></i>Требования</h5>
                    <p class="text-secondary" style="white-space: pre-line;">@Model.Requirements</p>
                </div>
                <div class="col-md-4 border-start">
                    <div class="ps-md-3">
                        <h6 class="text-muted text-uppercase small fw-bold">Условия</h6>
                        <p><strong>График:</strong> @Model.Schedule</p>
                        
                        <h6 class="text-muted text-uppercase small fw-bold mt-4">Дата публикации</h6>
                        <p>@Model.CreatedDate.ToString("D")</p>
                        <div class="d-grid gap-2 mt-5">
                            <a asp-controller="Application"
                                   asp-action="Apply"
                                   asp-route-vacancyId="@Model.Id"
                                   class="btn btn-primary btn-lg shadow-sm">
                                <i class="bi bi-send-plus me-2"></i> Откликнуться на вакансию
                            </a>
    
                            <div class="d-flex gap-2">
                                @if (User.IsInRole("Employer") || User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary w-100">Редактировать</a>
                                }
                                <a asp-action="Index" class="btn btn-light border w-100">Назад к списку</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>