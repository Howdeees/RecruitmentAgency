@model IEnumerable<RecruitmentAgency.Models.Resume>

@{
    ViewData["Title"] = "База резюме";
}

<div class="container mt-4 pb-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-2">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Главная</a></li>
                    <li class="breadcrumb-item active">Все резюме</li>
                </ol>
            </nav>
            <h2 class="fw-bold mb-0"><i class="bi bi-database-fill-gear me-2 text-primary"></i>Единая база кандидатов</h2>
        </div>
        <div class="text-end">
            <span class="badge bg-white text-primary border shadow-sm px-3 py-2">
                Найдено профилей: @Model.Count()
            </span>
        </div>
    </div>

    <div class="row g-3">
        @foreach (var item in Model)
        {
            // Проверяем статус рекомендации
            bool isRecommended = item.Applications?.Any(a => a.Status == RecruitmentAgency.Models.ApplicationStatus.Recommended) ?? false;

            <div class="col-12">
                <div class="card border-0 shadow-sm hover-row transition-all @(isRecommended ? "border-start border-4 border-warning" : "")">
                    <div class="card-body p-3">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                @if (!string.IsNullOrEmpty(item.ProfilePicture))
                                {
                                    <img src="/uploads/avatars/@item.ProfilePicture" 
                                         class="rounded-3 shadow-sm" 
                                         style="width: 80px; height: 80px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-light rounded-3 d-flex align-items-center justify-content-center border" 
                                         style="width: 80px; height: 80px;">
                                        <i class="bi bi-person text-muted fs-2"></i>
                                    </div>
                                }
                            </div>

                            <div class="col">
                                <div class="d-flex align-items-center mb-1">
                                    <h5 class="fw-bold mb-0 me-2">@item.FullName</h5>
                                    @if (isRecommended)
                                    {
                                        <span class="badge bg-warning text-dark rounded-pill" style="font-size: 0.65rem;">
                                            <i class="bi bi-star-fill"></i> В ФОНДЕ
                                        </span>
                                    }
                                </div>
                                <div class="text-primary fw-medium mb-1">@item.Title</div>
                                <div class="text-muted small">
                                    <i class="bi bi-mortarboard me-1"></i> @(item.Education?.Length > 60 ? item.Education.Substring(0, 60) + "..." : item.Education)
                                </div>
                            </div>

                            <div class="col-md-2 text-md-end border-start border-end px-4">
                                <div class="fw-bold text-dark">
                                    @(item.ExpectedSalary.HasValue ? item.ExpectedSalary?.ToString("N0") + " ₽" : "З/П не указана")
                                </div>
                                <div class="text-muted x-small mt-1">
                                    Обновлено: @item.UpdatedDate.ToString("dd.MM.yy")
                                </div>
                            </div>

                            <div class="col-md-3 ps-4">
                                <div class="d-flex flex-column gap-2">
                                    <div class="d-flex gap-2">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary w-100 fw-bold">
                                            Профиль
                                        </a>
                                        
                                        @if (User.IsInRole("Admin") || User.IsInRole("Recruiter"))
                                        {
                                            <button class="btn btn-sm @(isRecommended ? "btn-warning" : "btn-outline-warning")" 
                                                    type="button" data-bs-toggle="collapse" data-bs-target="#quickRec-@item.Id">
                                                <i class="bi @(isRecommended ? "bi-star-fill" : "bi-star")"></i>
                                            </button>
                                        }
                                    </div>
                                    
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <div class="d-flex gap-2">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light border text-muted w-100">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Удалить резюме?')">
                                                <button type="submit" class="btn btn-sm btn-light border text-danger">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="collapse mt-3" id="quickRec-@item.Id">
                            <form asp-action="AddToTalentPool" method="post" class="p-3 bg-light rounded border border-warning shadow-sm">
                                <input type="hidden" name="resumeId" value="@item.Id" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text bg-warning border-warning"><i class="bi bi-chat-left-quote"></i></span>
                                    <input type="text" name="comment" class="form-control border-warning" placeholder="Краткий комментарий рекрутера..." required />
                                    <button class="btn btn-warning fw-bold" type="submit">Добавить в фонд</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <style>
        body { background-color: #f4f6f9; }
        .hover-row { transition: all 0.2s; border: 1px solid transparent; }
        .hover-row:hover { 
            background-color: #fff; 
            transform: scale(1.01); 
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.1) !important;
            border-color: #dee2e6;
        }
        .x-small { font-size: 0.7rem; }
        .transition-all { transition: all 0.3s ease; }
    </style>
}