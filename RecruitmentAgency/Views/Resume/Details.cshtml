@model RecruitmentAgency.Models.Resume

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="mb-4">
                <a asp-action="Index" class="text-decoration-none text-muted">
                    <i class="bi bi-arrow-left me-1"></i> Вернуться к списку
                </a>
            </div>

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="row g-0">
                    <div class="col-md-4 bg-light border-end">
                        <div class="p-4 text-center">
                            <div class="mb-4">
                                @if (!string.IsNullOrEmpty(Model.ProfilePicture))
                                {
                                    <img src="/uploads/avatars/@Model.ProfilePicture" 
                                         class="rounded-circle shadow-sm border border-4 border-white" 
                                         style="width: 180px; height: 180px; object-fit: cover;" 
                                         alt="@Model.FullName" />
                                }
                                else
                                {
                                    <div class="bg-white rounded-circle d-inline-flex align-items-center justify-content-center shadow-sm border" 
                                         style="width: 180px; height: 180px;">
                                        <i class="bi bi-person text-light" style="font-size: 6rem;"></i>
                                    </div>
                                }
                            </div>

                            <h3 class="fw-bold mb-1">@Model.FullName</h3>
                            <p class="text-primary fw-medium mb-3">@Model.Title</p>
                            
                            @if (Model.ExpectedSalary.HasValue)
                            {
                                <div class="badge bg-white text-dark border px-3 py-2 rounded-pill shadow-sm mb-4">
                                    <span class="text-muted small">Ожидания:</span> 
                                    <span class="fw-bold text-success">@Model.ExpectedSalary?.ToString("N0") ₽</span>
                                </div>
                            }

                            <hr class="my-4">

                            <div class="text-start small px-2">
                                <p class="mb-2"><i class="bi bi-envelope me-2 text-muted"></i>@Model.User?.Email</p>
                                <p class="mb-0"><i class="bi bi-calendar-check me-2 text-muted"></i>Обновлено: @Model.UpdatedDate.ToString("dd.MM.yyyy")</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-8">
                        <div class="card-body p-4 p-md-5">
                            
                            <div class="mb-5">
                                <h5 class="fw-bold border-bottom pb-2 mb-3">
                                    <i class="bi bi-stars text-warning me-2"></i>Ключевые навыки
                                </h5>
                                <div class="d-flex flex-wrap gap-2">
                                    @if (!string.IsNullOrEmpty(Model.Skills))
                                    {
                                        foreach (var skill in Model.Skills.Split(','))
                                        {
                                            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-3 border border-primary border-opacity-25">
                                                @skill.Trim()
                                            </span>
                                        }
                                    }
                                </div>
                            </div>

                            <div class="mb-5">
                                <h5 class="fw-bold border-bottom pb-2 mb-3">
                                    <i class="bi bi-briefcase text-primary me-2"></i>Опыт работы
                                </h5>
                                <div class="text-dark" style="white-space: pre-line; line-height: 1.6;">
                                    @Model.Experience
                                </div>
                            </div>

                            <div class="mb-5">
                                <h5 class="fw-bold border-bottom pb-2 mb-3">
                                    <i class="bi bi-mortarboard text-danger me-2"></i>Образование
                                </h5>
                                <div class="text-muted">
                                    @if (!string.IsNullOrEmpty(Model.Education))
                                    {
                                        <div style="white-space: pre-line;">@Model.Education</div>
                                    }
                                    else
                                    {
                                        <span>Информация не указана</span>
                                    }
                                </div>
                            </div>

                            <div class="d-flex gap-2 mt-5">
                                @if (User.Identity.Name == Model.User?.Email || User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary px-4">
                                        <i class="bi bi-pencil me-2"></i>Редактировать
                                    </a>
                                }

                                @if (User.IsInRole("Admin") || User.IsInRole("Recruiter"))
                                {
                                    @* Наша форма добавления в Золотой фонд *@
                                    <button class="btn btn-warning px-4 fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#talentPoolForm">
                                        <i class="bi bi-star-fill me-2"></i>Рекомендовать
                                    </button>
                                }
                            </div>

                            <div class="collapse mt-3" id="talentPoolForm">
                                <div class="card card-body bg-light border-warning shadow-sm">
                                    <form asp-action="AddToTalentPool" method="post">
                                        <input type="hidden" name="resumeId" value="@Model.Id" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                        <div class="mb-3">
                                            <label class="form-label small fw-bold text-muted text-uppercase">Ваш отзыв для работодателя</label>
                                            <textarea name="comment" class="form-control border-0 shadow-sm" rows="3" placeholder="Почему этот кандидат подходит?"></textarea>
                                        </div>
                                        <button type="submit" class="btn btn-warning w-100 shadow-sm fw-bold">Подтвердить рекомендацию</button>
                                    </form>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        body { background-color: #f0f2f5; }
        .card { transition: all 0.3s ease; }
        .badge { font-weight: 500; }
        h5 { letter-spacing: 0.5px; }
    </style>
}