@model IEnumerable<RecruitmentAgency.Models.Resume>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-6 fw-bold">Мои резюме</h1>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-lg"></i> Создать резюме
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-light border shadow-sm text-center py-5">
            <p class="text-muted mb-0">У вас пока нет созданных резюме.</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var item in Model)
            {
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body">
                            <h5 class="fw-bold text-primary">@item.Title</h5>
                            <p class="text-muted small mb-3">Обновлено: @item.UpdatedDate.ToString("dd.MM.yyyy")</p>
                            <div class="mb-3">
                                <span class="badge bg-light text-dark border">Навыки: @(item.Skills.Length > 50 ? item.Skills.Substring(0, 50) + "..." : item.Skills)</span>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 pb-3">
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">Редактировать</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Просмотр</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>