@model IEnumerable<RecruitmentAgency.Models.Application>

@{
    ViewData["Title"] = "Мои отклики";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-6 fw-bold">Мои отклики</h1>
        <a asp-controller="Vacancy" asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-search me-1"></i> Найти еще вакансии
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm text-center p-5">
            <div class="card-body">
                <i class="bi bi-send-exclamation display-1 text-light mb-3"></i>
                <h3 class="text-muted">Вы еще никуда не откликались</h3>
                <p class="mb-4">Ваши будущие офферы ждут вас в разделе вакансий.</p>
                <a asp-controller="Vacancy" asp-action="Index" class="btn btn-primary btn-lg px-4">Перейти к вакансиям</a>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded-3">
            <table class="table table-hover align-middle bg-white mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Вакансия</th>
                        <th>Резюме</th>
                        <th>Дата подачи</th>
                        <th>Статус</th>
                        <th class="pe-4 text-end">Действие</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@item.Vacancy.Title</div>
                                <div class="text-muted small">ID вакансии: @item.VacancyId</div>
                            </td>
                            <td>
                                <a asp-controller="Resume" asp-action="Details" asp-route-id="@item.ResumeId" class="text-decoration-none">
                                    <i class="bi bi-file-earmark-person"></i> @item.Resume.Title
                                </a>
                            </td>
                            <td>@item.AppliedDate.ToString("dd.MM.yyyy")</td>
                            <td>
                                @* Цветовая схема для статусов *@
                                @{
                                    var badgeClass = item.Status switch
                                    {
                                        ApplicationStatus.New => "bg-info",
                                        ApplicationStatus.UnderReview => "bg-warning text-dark",
                                        ApplicationStatus.Accepted => "bg-success",
                                        ApplicationStatus.Rejected => "bg-danger",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass px-3 py-2">
                                    @Html.DisplayFor(modelItem => item.Status)
                                </span>
                            </td>
                            <td class="pe-4 text-end">
                                <a asp-controller="Vacancy" asp-action="Details" asp-route-id="@item.VacancyId" class="btn btn-sm btn-light border shadow-sm">
                                    О вакансии
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>