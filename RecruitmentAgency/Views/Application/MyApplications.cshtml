@model IEnumerable<RecruitmentAgency.Models.Application>

@{
    ViewData["Title"] = "Мои отклики";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6 fw-bold mb-0">Мои отклики</h1>
            <p class="text-muted">Отслеживайте статус ваших заявок в реальном времени</p>
        </div>
        <a asp-controller="Vacancy" asp-action="Index" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Найти вакансии
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm text-center p-5 bg-white">
            <div class="card-body">
                <div class="mb-4">
                    <i class="bi bi-briefcase-flood display-1 text-light"></i>
                </div>
                <h3 class="fw-bold">Список пуст</h3>
                <p class="text-muted mb-4">Вы еще не отправляли откликов на вакансии нашего агентства.</p>
                <a asp-controller="Vacancy" asp-action="Index" class="btn btn-primary px-5 rounded-pill">Начать поиск</a>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="text-muted small fw-bold text-uppercase">
                            <th class="ps-4 py-3">Вакансия</th>
                            <th class="py-3">Используемое резюме</th>
                            <th class="py-3">Дата подачи</th>
                            <th class="py-3">Текущий статус</th>
                            <th class="pe-4 py-3 text-end">Действие</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-primary">@item.Vacancy.Title</div>
                                    <div class="text-muted x-small">Ref: #@item.VacancyId</div>
                                </td>
                                <td>
                                    <a asp-controller="Resume" asp-action="Details" asp-route-id="@item.ResumeId" 
                                       class="text-decoration-none text-dark d-flex align-items-center">
                                        <i class="bi bi-file-earmark-person-fill text-secondary me-2"></i>
                                        <span>@item.Resume.Title</span>
                                    </a>
                                </td>
                                <td class="text-muted">
                                    @item.AppliedDate.ToString("dd MMM yyyy")
                                </td>
                                <td>
                                    @{
                                        var (badgeClass, statusName) = item.Status switch
                                        {
                                            RecruitmentAgency.Models.ApplicationStatus.New => ("bg-info text-white", "Новый"),
                                            RecruitmentAgency.Models.ApplicationStatus.UnderReview => ("bg-warning text-dark", "На рассмотрении"),
                                            RecruitmentAgency.Models.ApplicationStatus.Accepted => ("bg-success text-white", "Принят"),
                                            RecruitmentAgency.Models.ApplicationStatus.Rejected => ("bg-danger text-white", "Отказ"),
                                            RecruitmentAgency.Models.ApplicationStatus.RejectedEmployer => ("bg-danger text-white", "Отказ работодателем"),
                                            RecruitmentAgency.Models.ApplicationStatus.RejectedRecruiter => ("bg-danger text-white", "Отказ рекрутером"),
                                            RecruitmentAgency.Models.ApplicationStatus.Interview => ("bg-danger text-white", "Собеседование"),
                                            _ => ("bg-secondary text-white", item.Status.ToString())
                                        };
                                    }
                                    <span class="badge @badgeClass rounded-pill px-3 py-2 fw-medium">
                                        @statusName
                                    </span>
                                </td>
                                <td class="pe-4 text-end">
                                    <a asp-controller="Vacancy" asp-action="Details" asp-route-id="@item.VacancyId" 
                                       class="btn btn-sm btn-outline-secondary rounded-pill">
                                        <i class="bi bi-eye me-1"></i> О вакансии
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@section Scripts {
    <style>
        .x-small { font-size: 0.75rem; }
        .table thead th { border-bottom: none; }
        .table tbody tr { transition: background-color 0.2s; }
        .table tbody tr:hover { background-color: #f8f9ff !important; }
        .badge { font-size: 0.8rem; letter-spacing: 0.3px; }
    </style>
}