@model IEnumerable<RecruitmentAgency.Models.Application>

@{
    ViewData["Title"] = "Управление откликами";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0 text-primary"><i class="bi bi-person-lines-fill me-2"></i>Управление откликами</h2>
        <div class="d-flex gap-2 align-items-center">
            <span class="badge bg-primary shadow-sm px-3">Всего: @Model.Count()</span>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-white">
        <div class="card-body p-3">
            <form method="get" asp-action="Incoming" class="row g-2 align-items-end">
                <div class="col-md-6">
                    <label class="form-label small fw-bold text-muted">Фильтр по вакансии</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-filter"></i></span>
                        <select name="vacancyId" class="form-select border-0 bg-light shadow-none" onchange="this.form.submit()">
                            <option value="">Все активные вакансии</option>
                            @foreach (var v in ViewBag.Vacancies)
                            {
                                <!option value="@v.Id" @(v.Id == ViewBag.SelectedVacancyId ? "selected" : "")>@v.Title</!option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    @if (ViewBag.SelectedVacancyId != null)
                    {
                        <a asp-action="Incoming" class="btn btn-outline-secondary w-100"><i class="bi bi-x-circle me-1"></i>Сброс</a>
                    }
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr class="text-uppercase small fw-bold text-muted">
                        <th class="ps-4 py-3">Кандидат</th>
                        <th class="py-3">Вакансия</th>
                        <th class="py-3 text-center">Дата</th>
                        <th class="py-3" style="min-width: 250px;">Статус и Заметки</th>
                        <th class="py-3 pe-4 text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-circle me-3">
                                        @(string.IsNullOrEmpty(item.Resume.FullName) ? "?" : item.Resume.FullName.Substring(0, 1).ToUpper())
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@item.Resume.FullName</div>
                                        <div class="text-muted small"><i class="bi bi-envelope me-1"></i>@item.User.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (item.Vacancy != null)
                                {
                                    <a asp-controller="Vacancy" 
                                       asp-action="Details" 
                                       asp-route-id="@item.Id" 
                                       class="text-decoration-none fw-bold text-primary">
                                        <i class="bi bi-briefcase me-1"></i>@item.Vacancy.Title
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">Вакансия удалена</span>
                                }
                            </td>
                            <td class="text-center text-muted small">
                                <div class="fw-bold text-dark">@item.AppliedDate.ToString("dd.MM.yyyy")</div>
                                <div>@item.AppliedDate.ToString("HH:mm")</div>
                            </td>
                            <td>
                                <form asp-action="UpdateStatus" method="post" class="row g-1 align-items-center">
                                    <input type="hidden" name="applicationId" value="@item.Id" />
                                    <input type="hidden" name="currentVacancyId" value="@ViewBag.SelectedVacancyId" />
                                    
                                    <div class="col-12 mb-1">
                                        <select name="status" class="form-select form-select-sm status-select shadow-none w-100" 
                                                onchange="this.form.submit()">
                                            @foreach (var status in Enum.GetValues(typeof(RecruitmentAgency.Models.ApplicationStatus)))
                                            {
                                                string displayName = status.ToString() switch
                                                {
                                                    "New" => "🆕 Новый",
                                                    "UnderReview" => "⏳ На рассмотрении",
                                                    "Accepted" => "✅ Принят",
                                                    "Rejected" => "❌ Отказ",
                                                    "RejectedEmployer" => "🚫 Отказ (Раб.)",
                                                    "RejectedRecruiter" => "⚠️ Отказ (Рекр.)",
                                                    "Interview" => "📅 Собеседование",
                                                    _ => status.ToString()
                                                };

                                                <!option value="@status" @((RecruitmentAgency.Models.ApplicationStatus)status == item.Status ? "selected" : "")>
                                                    @displayName
                                                </!option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-12">
                                        <div class="input-group input-group-sm">
                                            <input type="text" name="note" value="@item.RecruiterNotes" 
                                                   class="form-control border-light-subtle shadow-none small" 
                                                   placeholder="Ваша заметка..." style="font-size: 0.8rem;" />
                                            <button type="submit" class="btn btn-success" title="Сохранить заметку">
                                                <i class="bi bi-check2"></i>
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </td>
                            <td class="pe-4 text-end">
                                <div class="btn-group shadow-sm bg-white rounded">
                                    <a href="mailto:@item.User.Email?subject=Отклик на вакансию: @item.Vacancy.Title" 
                                       class="btn btn-sm btn-outline-success">
                                        <i class="bi bi-send-fill"></i>
                                    </a>
                                    <a asp-controller="Resume" asp-action="Details" asp-route-id="@item.ResumeId" 
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye-fill"></i>
                                    </a>
                                    <button class="btn btn-sm btn-light border" type="button" 
                                            data-bs-toggle="collapse" data-bs-target="#letter-@item.Id">
                                        <i class="bi bi-chat-left-text"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        <tr class="collapse" id="letter-@item.Id">
                            <td colspan="5" class="bg-light border-bottom">
                                <div class="p-3 mx-4 my-2 bg-white shadow-sm border-start border-4 border-primary rounded">
                                    <h6 class="fw-bold small text-primary mb-1">Сопроводительное письмо:</h6>
                                    <p class="mb-0 text-secondary small lh-base" style="white-space: pre-line;">
                                        @(string.IsNullOrWhiteSpace(item.CoverLetter) ? "Без письма." : item.CoverLetter)
                                    </p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        body { background-color: #f4f7f6; }
        .avatar-circle {
            width: 40px; height: 40px;
            background: linear-gradient(135deg, #4b6cb7 0%, #182848 100%);
            border-radius: 10px; display: flex; align-items: center; justify-content: center;
            font-weight: 600; color: white; box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        .status-select { border-radius: 6px; font-weight: 500; }
        .table-hover tbody tr:hover { background-color: rgba(0,0,0,0.01); }
        
        /* Цвета для границ селекта */
        select[name="status"]:has(option[value="New"]:checked) { border-left: 4px solid #0dcaf0; }
        select[name="status"]:has(option[value="Accepted"]:checked) { border-left: 4px solid #198754; }
        select[name="status"]:has(option[value="Rejected"]:checked),
        select[name="status"]:has(option[value="RejectedEmployer"]:checked),
        select[name="status"]:has(option[value="RejectedRecruiter"]:checked) { border-left: 4px solid #dc3545; }
        select[name="status"]:has(option[value="Interview"]:checked) { border-left: 4px solid #0d6efd; }
    </style>
}