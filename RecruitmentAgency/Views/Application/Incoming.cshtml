@model IEnumerable<RecruitmentAgency.Models.Application>

<div class="container mt-4">
    <h2 class="fw-bold mb-4">Управление откликами</h2>

    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body">
            <form method="get" asp-action="Incoming" class="row g-3 align-items-end">
                <div class="col-md-6">
                    <label class="form-label small fw-bold">Фильтр по вакансии</label>
                    <select name="vacancyId" class="form-select search-group" onchange="this.form.submit()">
                        <option value="">Все вакансии</option>
                        @foreach (var v in ViewBag.Vacancies)
                        {
                            if (v.Id == ViewBag.SelectedVacancyId)
                            {
                                <option value="@v.Id" selected>@v.Title</option>
                            }
                            else
                            {
                                <option value="@v.Id">@v.Title</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    @if (ViewBag.SelectedVacancyId != null)
                    {
                        <a asp-action="Incoming" class="btn btn-outline-secondary w-100">Сбросить</a>
                    }
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="text-uppercase small fw-bold">
                            <th class="ps-4 py-3">Кандидат</th>
                            <th class="py-3">Вакансия</th>
                            <th class="py-3 text-center">Дата</th>
                            <th class="py-3">Резюме</th>
                            <th class="py-3 pe-4 text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-3">@item.User.UserName.Substring(0, 1).ToUpper()</div>
                                        <div>
                                            <div class="fw-bold">@item.User.UserName</div>
                                            <div class="text-muted small">@item.User.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="fw-medium">@item.Vacancy.Title</span>
                                </td>
                                <td class="text-center text-muted small">
                                    @item.AppliedDate.ToString("dd.MM.yyyy HH:mm")
                                </td>
                                <td>
                                    <a asp-controller="Resume" asp-action="Details" asp-route-id="@item.ResumeId" 
                                       class="btn btn-outline-primary btn-sm rounded-pill px-3 shadow-sm-hover">
                                        <i class="bi bi-file-earmark-person me-1"></i> Резюме
                                    </a>
                                </td>
                                <td class="pe-4 text-end">
                                    <button class="btn btn-link text-decoration-none" type="button" 
                                            data-bs-toggle="collapse" data-bs-target="#letter-@item.Id">
                                        Прочитать письмо <i class="bi bi-chevron-down ms-1"></i>
                                    </button>
                                </td>
                            </tr>
                            <tr class="collapse" id="letter-@item.Id">
                                <td colspan="5" class="bg-light border-0 p-0">
                                    <div class="p-4 mx-4 my-2 border-start border-4 border-primary bg-white shadow-sm rounded">
                                        <h6 class="fw-bold mb-3"><i class="bi bi-chat-left-dots me-2"></i>Сопроводительное письмо:</h6>
                                        <p class="mb-0 text-secondary" style="white-space: pre-line;">@item.CoverLetter</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@section Scripts {
    <style>
        .avatar-circle {
            width: 40px;
            height: 40px;
            background-color: #e9ecef;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            color: #6c757d;
        }
        .shadow-sm-hover:hover {
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        }
    </style>
}