@model IEnumerable<RecruitmentAgency.Models.Application>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0 text-primary"><i class="bi bi-person-lines-fill me-2"></i>Управление откликами</h2>
        <span class="badge bg-secondary">Всего: @Model.Count()</span>
    </div>

    @* Панель фильтров *@
    <div class="card shadow-sm border-0 mb-4 bg-white">
        <div class="card-body p-3">
            <form method="get" asp-action="Incoming" class="row g-2 align-items-end">
                <div class="col-md-6">
                    <label class="form-label small fw-bold text-muted">Фильтр по вакансии</label>
                    <select name="vacancyId" class="form-select border-0 bg-light" onchange="this.form.submit()">
                        <option value="">Все активные вакансии</option>
                        @foreach (var v in ViewBag.Vacancies)
                        {
                            <option value="@v.Id" selected="@(v.Id == ViewBag.SelectedVacancyId)">@v.Title</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    @if (ViewBag.SelectedVacancyId != null)
                    {
                        <a asp-action="Incoming" class="btn btn-outline-secondary w-100"><i class="bi bi-x-circle me-1"></i>Сброс</a>
                    }
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr class="text-uppercase small fw-bold text-muted">
                        <th class="ps-4 py-3">Кандидат</th>
                        <th class="py-3">Вакансия</th>
                        <th class="py-3 text-center">Дата</th>
                        <th class="py-3">Статус</th>
                        <th class="py-3 pe-4 text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-circle me-3">@item.Resume.FullName.Substring(0, 1).ToUpper()</div>
                                    <div>
                                        <div class="fw-bold text-dark">@item.Resume.FullName</div>
                                        <div class="text-muted small">@item.User.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="badge bg-light text-dark border fw-medium">@item.Vacancy.Title</div>
                            </td>
                            <td class="text-center text-muted small">
                                @item.AppliedDate.ToString("dd.MM.yyyy")<br />
                                @item.AppliedDate.ToString("HH:mm")
                            </td>
                            <td>
                                @* Форма смены статуса с переводом *@
                                <form asp-action="UpdateStatus" method="post" class="d-inline">
                                    <input type="hidden" name="applicationId" value="@item.Id" />
                                    <select name="newStatus" class="form-select form-select-sm status-select" 
                                            onchange="this.form.submit()">
                                        @foreach (var status in Enum.GetValues(typeof(RecruitmentAgency.Models.ApplicationStatus)))
                                        {
                                            // Маппинг на русский язык
                                            string displayName = status.ToString() switch
                                            {
                                                "New" => "Новый",
                                                "UnderReview" => "На рассмотрении",
                                                "Accepted" => "Принят",
                                                "Rejected" => "Отказ",
                                                "RejectedEmployer" => "Отказ работодателем",
                                                "RejectedRecruiter" => "Отказ рекрутером",
                                                "Interview" => "Собеседование",
                                                _ => status.ToString()
                                            };

                                            <option value="@status" selected="@((RecruitmentAgency.Models.ApplicationStatus)status == item.Status)">
                                                @displayName
                                            </option>
                                        }
                                    </select>
                                </form>
                            </td>
                            <td class="pe-4 text-end">
                                <div class="btn-group">
                                    <a href="mailto:@item.User.Email?subject=Отклик на вакансию: @item.Vacancy.Title&body=Здравствуйте, @item.Resume.FullName! Мы рассмотрели ваш отклик..." 
                                       class="btn btn-sm btn-outline-success" 
                                       title="Написать письмо">
                                        <i class="bi bi-envelope-at"></i>
                                    </a>
                                    <a asp-controller="Resume" asp-action="Details" asp-route-id="@item.ResumeId" 
                                       class="btn btn-sm btn-outline-primary" title="Посмотреть резюме">
                                        <i class="bi bi-file-earmark-person"></i>
                                    </a>
                                    <button class="btn btn-sm btn-light border" type="button" 
                                            data-bs-toggle="collapse" data-bs-target="#letter-@item.Id" title="Письмо">
                                        <i class="bi bi-chat-right-text"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        @* Строка с письмом внутри основной таблицы *@
                        <tr class="collapse" id="letter-@item.Id">
                            <td colspan="5" class="bg-light p-0">
                                <div class="p-3 mx-4 my-2 bg-white shadow-sm border-start border-4 border-primary rounded">
                                    <h6 class="fw-bold small text-primary mb-2">Сопроводительное письмо:</h6>
                                    <p class="mb-0 text-secondary small" style="white-space: pre-line;">@item.CoverLetter</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .avatar-circle {
            width: 38px;
            height: 38px;
            background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            color: white;
            font-size: 0.9rem;
        }
        .status-select {
            min-width: 140px;
            border-radius: 20px;
            padding-left: 12px;
            font-size: 0.85rem;
            cursor: pointer;
            transition: all 0.2s;
        }
        .status-select:hover {
            border-color: #0d6efd;
            background-color: #f8f9fa;
        }
        .table-hover tbody tr:hover {
            background-color: rgba(13, 110, 253, 0.02);
        }
    </style>
}