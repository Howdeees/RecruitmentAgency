@model StatsViewModel
<div class="container mt-4">
    <h2 class="fw-bold mb-4 text-dark"><i class="bi bi-graph-up-arrow me-2"></i>Аналитика системы</h2>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white p-3 h-100">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="small text-white-50">Всего вакансий</div>
                        <h2 class="fw-bold mb-0">@Model.TotalVacancies</h2>
                    </div>
                    <i class="bi bi-briefcase fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-success text-white p-3 h-100">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="small text-white-50">Нанято (Accepted)</div>
                        <h2 class="fw-bold mb-0">@Model.HiredCount</h2>
                    </div>
                    <i class="bi bi-person-check fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-warning text-dark p-3 h-100">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="small text-black-50">Всего откликов</div>
                        <h2 class="fw-bold mb-0">@Model.TotalApplications</h2>
                    </div>
                    <i class="bi bi-people fs-1 opacity-25"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-info text-white p-3 h-100">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="small text-white-50">Конверсия</div>
                        <h2 class="fw-bold mb-0">
                            @(Model.TotalApplications > 0 ? (Model.HiredCount * 100 / Model.TotalApplications) : 0)%
                        </h2>
                    </div>
                    <i class="bi bi-percent fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white fw-bold py-3">Воронка откликов</div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        @foreach (var status in Model.ApplicationsByStatus)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center ps-0">
                                <span>@status.Key</span>
                                <span class="badge bg-secondary rounded-pill">@status.Value</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white fw-bold py-3">Топ вакансий по откликам</div>
                <div class="card-body">
                    @foreach (var v in Model.TopVacancies)
                    {
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1 small">
                                <span>@v.Title</span>
                                <span class="fw-bold">@v.Count</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                @{
                                    var percent = Model.TotalApplications > 0 ? (v.Count * 100 / Model.TotalApplications) : 0;
                                }
                                <div class="progress-bar bg-primary" style="width: @percent%"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>