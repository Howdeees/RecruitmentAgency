@model IEnumerable<UserRolesViewModel>

<div class="container mt-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-shield-lock me-2"></i>Управление пользователями</h2>

    <div class="card shadow-sm border-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">Email пользователя</th>
                    <th>Текущая роль</th>
                    <th class="pe-4 text-end">Назначить новую роль</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@user.Email</td>
                        <td>
                            @foreach (var role in user.Roles)
                            {
                                <span class="badge bg-primary rounded-pill px-3">@role</span>
                            }
                            @if (!user.Roles.Any())
                            {
                                <span class="badge bg-light text-muted">Нет роли</span>
                            }
                        </td>
                        <td class="pe-4">
                            <form asp-action="UpdateRole" method="post" class="d-flex justify-content-end gap-2">
                                <input type="hidden" name="userId" value="@user.UserId" />
                                <select name="newRole" class="form-select form-select-sm w-auto shadow-sm">
                                    <option value="">Без роли (Candidate)</option>
                                    @foreach (var role in ViewBag.AllRoles)
                                    {
                                        <option value="@role">@role</option>
                                    }
                                </select>
                                <button type="submit" class="btn btn-sm btn-dark">Ок</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>